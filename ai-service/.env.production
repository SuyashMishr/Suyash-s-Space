# AI Service Production Environment
ENVIRONMENT=production

# API Configuration
PORT=10000
HOST=0.0.0.0

# Security
API_KEY=secure-ai-api-key-change-this
CORS_ORIGINS=https://your-backend.onrender.com,https://your-portfolio-frontend.vercel.app

# AI Configuration
MAX_TOKENS=150
TEMPERATURE=0.7
MODEL_NAME=simple-ai

# Performance
UVICORN_WORKERS=2
UVICORN_LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_PERIOD=60
