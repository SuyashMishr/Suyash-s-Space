# Admin Panel Production Environment
REACT_APP_API_URL=https://your-backend.onrender.com
REACT_APP_FRONTEND_URL=https://your-portfolio-frontend.vercel.app
REACT_APP_ENV=production

# Admin Features
REACT_APP_ENABLE_ADMIN_REGISTRATION=false
REACT_APP_ADMIN_PANEL_TITLE=Portfolio Admin
REACT_APP_MAX_UPLOAD_SIZE=5242880

# Security
REACT_APP_SESSION_TIMEOUT=3600000
REACT_APP_AUTO_LOGOUT=true

# Performance
GENERATE_SOURCEMAP=false
